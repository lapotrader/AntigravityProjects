V1 = HIGH - LOW
V2 = HIGH - CLOSE[1]
IF V2 < 0 THEN
   V2 = -V2
ENDIF
V3 = LOW - CLOSE[1]
IF V3 < 0 THEN
   V3 = -V3
ENDIF
TRV = V1
IF V2 > TRV THEN
   TRV = V2
ENDIF
IF V3 > TRV THEN
   TRV = V3
ENDIF

IF BARINDEX = 1 THEN
   AV = TRV
ELSE
   AV = AV[1] + (TRV - AV[1]) / 30
ENDIF

HP = (HIGH + LOW) / 2
BU = HP + 1.5 * AV
BL = HP - 1.5 * AV

IF BARINDEX = 1 THEN
   FBU = BU
   FBL = BL
   PL = FBU
   D = -1
ELSE
   IF BU < FBU[1] OR CLOSE[1] > FBU[1] THEN
      FBU = BU
   ELSE
      FBU = FBU[1]
   ENDIF
   IF BL > FBL[1] OR CLOSE[1] < FBL[1] THEN
      FBL = BL
   ELSE
      FBL = FBL[1]
   ENDIF

   IF D[1] = -1 THEN
      IF CLOSE > FBU THEN
         PL = FBL
         D = 1
      ELSE
         PL = FBU
         D = -1
      ENDIF
   ELSE
      IF CLOSE < FBL THEN
         PL = FBU
         D = -1
      ELSE
         PL = FBL
         D = 1
      ENDIF
   ENDIF
ENDIF

RETURN PL
